<Window x:Class="WpfApp1.EditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Profile"
        Height="490"
        Width="320"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1F2A44">

    <Border Background="#3A3F7A" CornerRadius="10" Padding="20" Margin="10">
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Text="Edit Profile"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <!-- Name -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Name" FontWeight="SemiBold" Foreground="White"/>
                <TextBox Height="30"
                         Margin="0,5,0,0"
                         Padding="5"
                         Foreground="White"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <!-- Description -->
            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="Description" FontWeight="SemiBold" Foreground="White"/>
                <TextBox Height="90"
                         Margin="0,5,0,0"
                         Padding="5"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Foreground="White"
                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <!-- Image -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Top">
                <Border Width="70" Height="70" CornerRadius="35" ClipToBounds="True" Margin="0,0,15,0">
                    <Image Source="{Binding ProfileImage}" Stretch="Fill"/>
                </Border>

                <Button Content="Upload Image"
                        Width="120"
                        Height="30"
                        VerticalAlignment="Center"
                        Click="UploadImage_Click"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,25,0,0">

                <Button Content="Confirm"
                        Width="100"
                        Height="32"
                        Margin="0,0,10,0"
                        Click="ConfirmButton_Click"/>

                <Button Content="Cancel"
                        Width="100"
                        Height="32"
                        Click="CancelButton_Click"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>
