<Window x:Class="WpfApp1.GameDetailsWindowList"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Details"
        Height="601"
        Width="714"
        Background="#1E2A47">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Bouton info -->
        <Button Width="40"
            Height="40"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="#324878"
            Foreground="White"
            BorderThickness="0"
            Click="InfoButton_Click">

            <TextBlock Text="i"
               FontSize="20"
               FontWeight="Bold"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"/>
        </Button>

        <StackPanel Grid.Row="1">

            <!-- Bannière -->
            <Grid Height="160" Margin="0,10,0,15">

                <Border CornerRadius="10" ClipToBounds="True">
                    <Image Source="{Binding Illustration}"
               Stretch="UniformToFill"/>
                </Border>

                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#AA000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

            </Grid>

            <!-- Nom -->
            <TextBlock Text="{Binding Name}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,15,0,15"/>

            <!-- Time -->
            <Border Background="#324878"
                    CornerRadius="8"
                    Padding="10"
                    Margin="0,5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Time played (h)"
                               Foreground="#A8B3CF"
                               Width="150"/>
                    <TextBox Text="{Binding Time, UpdateSourceTrigger=PropertyChanged}"
                             Width="60"/>
                </StackPanel>
            </Border>

            <!-- Score -->
            <Border Background="#324878"
                    CornerRadius="8"
                    Padding="10"
                    Margin="0,5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Score (0-10)"
                               Foreground="#A8B3CF"
                               Width="150"/>
                    <TextBox Text="{Binding Score, UpdateSourceTrigger=PropertyChanged}"
                             Width="60"/>
                </StackPanel>
            </Border>

            <!-- State -->
            <Border Background="#324878"
                    CornerRadius="8"
                    Padding="10"
                    Margin="0,5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="State"
                               Foreground="#A8B3CF"
                               Width="150"/>
                    <ComboBox x:Name="StateComboBox"
                              Width="140"
                              SelectedItem="{Binding State, Mode=TwoWay}"/>
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,20,0,0">

                <Button Content="Confirm Changes"
                        Width="160"
                        Height="35"
                        Background="#7952C0"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="0,0,10,0"
                        Click="ConfirmButton_Click"/>

                <Button Content="Remove from list"
                        Width="160"
                        Height="35"
                        Background="#D9534F"
                        Foreground="White"
                        BorderThickness="0"
                        Click="RemoveButton_Click"/>

            </StackPanel>

        </StackPanel>

    </Grid>
</Window>
