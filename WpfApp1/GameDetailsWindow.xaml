<Window x:Class="WpfApp1.GameDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game details"
        Height="540"
        Width="493"
        Background="#1E2A47">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="20">

            <!-- Image -->
            <Border CornerRadius="10" ClipToBounds="True">
                <Image Source="{Binding Illustration}"
                       Height="200"
                       Stretch="UniformToFill"/>
            </Border>

            <!-- Title -->
            <TextBlock
                Text="{Binding Name}"
                FontSize="26"
                FontWeight="Bold"
                Foreground="White"
                Margin="0,15,0,10"/>

            <!-- Release -->
            <TextBlock Text="Release date"
                       Foreground="#A8B3CF"
                       FontWeight="SemiBold"/>

            <ItemsControl ItemsSource="{Binding release}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   Foreground="White"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Genre -->
            <TextBlock Text="Genre"
                       Foreground="#A8B3CF"
                       FontWeight="SemiBold"
                       Margin="0,15,0,5"/>

            <ItemsControl ItemsSource="{Binding genre}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#324878"
                                CornerRadius="10"
                                Padding="6,2"
                                Margin="3">
                            <TextBlock Text="{Binding}"
                                       Foreground="White"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Device -->
            <TextBlock Text="Devices"
                       Foreground="#A8B3CF"
                       FontWeight="SemiBold"
                       Margin="0,15,0,5"/>

            <ItemsControl ItemsSource="{Binding device}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#324878"
                                CornerRadius="10"
                                Padding="6,2"
                                Margin="3">
                            <TextBlock Text="{Binding}"
                                       Foreground="White"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Tags -->
            <TextBlock Text="Tags"
                       Foreground="#A8B3CF"
                       FontWeight="SemiBold"
                       Margin="0,15,0,5"/>

            <ItemsControl ItemsSource="{Binding tags}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#465F99"
                                CornerRadius="10"
                                Padding="6,2"
                                Margin="3">
                            <TextBlock Text="{Binding}"
                                       Foreground="White"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Button -->
            <Button Content="Add Game"
                    Margin="0,25,0,0"
                    Width="140"
                    Height="35"
                    Background="#7952C0"
                    Foreground="White"
                    BorderThickness="0"
                    Click="AddToUserGames_Click"
                    HorizontalAlignment="Left"/>
            

        </StackPanel>
    </ScrollViewer>
</Window>
